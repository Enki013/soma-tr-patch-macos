        <Entry Name="agentbark_attack_stalk_005_attackbot_001">Hadi bakalım, sıkı çocuk.</Entry>
        <Entry Name="agentbark_attack_stalk_006_attackbot_001">Kanama zamanı.</Entry>
        <Entry Name="agentbark_attack_stalk_007_attackbot_001">Seni deşip o kanı dışarı akıtacağım.</Entry>
        <Entry Name="agentbark_attack_stalk_008_attackbot_001">Şu kara kandan biraz akıtmak lazım.</Entry>
        <Entry Name="agentbark_attack_stalk_009_attackbot_001">Bana yakıtı ver.</Entry>
        <Entry Name="agentbark_attack_stalk_010_attackbot_001">Kendini kes.</Entry>
