        <Entry Name="agentbark_attack_stalk_012_attackbot_001">Hiçbir yere gitmiyorsun.</Entry>
        <Entry Name="agentbark_attack_stalk_013_attackbot_001">Gel buraya.</Entry>
        <Entry Name="agentbark_attack_stalk_014_attackbot_001">Gel buraya.</Entry>
