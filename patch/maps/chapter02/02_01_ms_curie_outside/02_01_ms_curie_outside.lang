        <Entry Name="agentbark_attack_stalkend_004_attackbot_001">Gitme! Kanamalısın!</Entry>
        <Entry Name="agentbark_attack_stalkend_005_attackbot_001">Hayır, kaçtı mı? Allah belanı versin!</Entry>
        <Entry Name="agentbark_attack_stalkend_006_attackbot_001">Seni amına koduğumun korkağı! Geri gel!</Entry>
        <Entry Name="agentbark_attack_searchstart_001_attackbot_001">Benden saklanmaya mı çalışıyorsun?</Entry>
        <Entry Name="agentbark_attack_searchstart_002_attackbot_001">İyi bir saklanma yeri bulsan iyi olur - senin için geliyorum.</Entry>
        <Entry Name="agentbark_attack_searchstart_003_attackbot_001">Seni bulacağım.</Entry>
        <Entry Name="agentbark_attack_searchstart_004_attackbot_001">Cidden seni aramamı mı sağlayacaksın?</Entry>
        <Entry Name="agentbark_attack_searchstart_005_attackbot_001">Saklandığın o deliği bulacağım.</Entry>
        <Entry Name="agentbark_attack_searchstart_006_attackbot_001">Seni bulacağım ve seni öldürececeğim.</Entry>
        <Entry Name="agentbark_attack_searchfound_001_attackbot_001">Seni buldum.</Entry>
        <Entry Name="agentbark_attack_searchfound_002_attackbot_001">Seni görüyorum.</Entry>
        <Entry Name="agentbark_attack_searchfound_003_attackbot_001">Oh, işte başlıyoruz.</Entry>
        <Entry Name="agentbark_attack_searchfound_004_attackbot_001">Buldum seni.</Entry>
        <Entry Name="agentbark_attack_searchfound_005_attackbot_001">Yakalandın.</Entry>
        <Entry Name="agentbark_attack_searchfound_006_attackbot_001">İşte buradasın.</Entry>
        <Entry Name="agentbark_attack_tempted_001_attackbot_001">Gel buraya!</Entry>
        <Entry Name="agentbark_attack_tempted_002_attackbot_001">Seni lime lime edeceğim!</Entry>
        <Entry Name="agentbark_attack_tempted_003_attackbot_001">Hayatın için dua et, küçük sıçan!</Entry>
        <Entry Name="agentbark_attack_tempted_004_attackbot_001">Senin için bitti!</Entry>
        <Entry Name="agentbark_attack_tempted_005_attackbot_001">Al bunu. Kancık gibi ağla!</Entry>
        <Entry Name="agentbark_attack_tempted_006_attackbot_001">Ölme zamanı!</Entry>
        <Entry Name="agentbark_attack_tempted_007_attackbot_001">Kaçacak hiçbir yer yok!</Entry>
        <Entry Name="agentbark_attack_tempted_008_attackbot_001">Geriye kalan tek şey ölüm!</Entry>
        <Entry Name="agentbark_attack_tempted_009_attackbot_001">Bana yakıtı ver!</Entry>
        <Entry Name="agentbark_attack_tempted_010_attackbot_001">Benim için kan dök!</Entry>
        <Entry Name="agentbark_attack_tempted_011_attackbot_001">Boku yedin!</Entry>
        <Entry Name="agentbark_attack_tempted_012_attackbot_001">Acı çekmeni istiyorum!</Entry>
        <Entry Name="agentbark_attack_tempted_013_attackbot_001">Acıyı hisset!</Entry>
        <Entry Name="agentbark_attack_tempted_014_attackbot_001">Kaçamayacaksın!</Entry>
        <Entry Name="agentbark_attack_tempted_015_attackbot_001">Burası öleceğin yer!</Entry>
        <Entry Name="agentbark_attack_tempted_016_attackbot_001">Hiçbir şeyin yok, hiçbir şeyin!</Entry>
        <Entry Name="agentbark_attack_tempted_017_attackbot_001">Kara kanı akıt!</Entry>
        <Entry Name="agentbark_attack_tempted_018_attackbot_001">Bu iş burada biter!</Entry>
        <Entry Name="agentbark_attack_tempted_019_attackbot_001">Geber!</Entry>
        <Entry Name="agentbark_attack_stalkstart_001_attackbot_001">İşte buradasın.</Entry>
        <Entry Name="agentbark_attack_stalkstart_002_attackbot_001">Hadi yapalım şunu.</Entry>
        <Entry Name="agentbark_attack_stalkstart_003_attackbot_001">Saklansan da saklanmasan da, geliyorum.</Entry>
        <Entry Name="agentbark_attack_stalkstart_004_attackbot_001">Bu eğlenceli olacak.</Entry>
        <Entry Name="agentbark_attack_stalkstart_005_attackbot_001">Ağzına sıçacağım.</Entry>
        <Entry Name="agentbark_attack_stalkstart_006_attackbot_001">İşte başlıyoruz.</Entry>
        <Entry Name="agentbark_attack_alert_001_attackbot_001">Kulaklarım var, biliyor musun?</Entry>
        <Entry Name="agentbark_attack_alert_002_attackbot_001">Her adımını duyuyorum, dostum.</Entry>
        <Entry Name="agentbark_attack_alert_003_attackbot_001">Seni duyabiliyorum. Saklanmayı bırak!</Entry>
        <Entry Name="agentbark_attack_alert_004_attackbot_001">Bunu duydum - göster kendini.</Entry>
        <Entry Name="agentbark_attack_alert_005_attackbot_001">Çok gürültülüsün.</Entry>
        <Entry Name="agentbark_attack_alert_006_attackbot_001">Bütün bu gürültüyü sen mi yapıyorsun?</Entry>
        <Entry Name="agentbark_attack_alert_007_attackbot_001">Seni duyuyorum, biliyorsun.</Entry>
        <Entry Name="agentbark_attack_alert_008_attackbot_001">Duyabiliyorum, kokunu alabiliyorum.</Entry>
        <Entry Name="agentbark_attack_alertbeforeseen_001_attackbot_001">Bu sesi ne çıkarıyor?</Entry>
        <Entry Name="agentbark_attack_alertbeforeseen_002_attackbot_001">Göster kendini!</Entry>
