<LANGUAGE>
    <CATEGORY Name="Voices_02_07_theta_exit">
        <Entry Name="wakingup_wakeup_1_001_ashley_001">Kıpırdama. Sorun yok.</Entry>
        <Entry Name="wakingup_wakeup_1_002_player_001">Ne?</Entry>
        <Entry Name="wakingup_wakeup_1_003_ashley_001">Artık bitti. Rahatla.</Entry>
        <Entry Name="wakingup_wakeup_1_004_player_001">Ashley? Senin burada ne işin var?</Entry>
        <Entry Name="wakingup_wakeup_1_005_ashley_001">Takılıyorum. Çiftlerin yaptığı gibi.</Entry>
        <Entry Name="wakingup_wakeup_1_006_player_001">Ama biz--</Entry>
        <Entry Name="wakingup_wakeup_1_007_ashley_001">Beni istemiyor musun?</Entry>
        <Entry Name="wakingup_wakeup_1_008_player_001">Evet, tabii ki -- ama ne oldu?</Entry>
        <Entry Name="wakingup_wakeup_1_009_ashley_001">Aşık olduk.</Entry>
        <Entry Name="wakingup_wakeup_2_001_player_001">Bu doğru, Simon. Gerçek dünyada kal -- boktan gerçek dünyada.</Entry>
        <Entry Name="victimbabbles_victimkoster_001_victimkoster_001">Brandon...</Entry>
        <Entry Name="victimbabbles_victimkoster_002_victimkoster_001">Geleceğini biliyordum.</Entry>
        <Entry Name="victimbabbles_victimkoster_003_victimkoster_001">Unutamayacak kadar romantiksin.</Entry>
        <Entry Name="victimbabbles_victimkoster_004_victimkoster_001">Ama bunu hatırlıyor musun?</Entry>
        <Entry Name="victimbabbles_victimkoster_005_victimkoster_001">Bana verdiğin kolye.</Entry>
        <Entry Name="victimbabbles_victimkoster_006_victimkoster_001">*kıkırdama*</Entry>
        <Entry Name="victimbabbles_victimkoster_007_victimkoster_001">Hadi, içeri girelim.</Entry>
        <Entry Name="victimbabbles_victimkoster_008_victimkoster_001">En iyi kahveyi yapıyorlar.</Entry>
        <Entry Name="victimbabbles_victimkoster_009_victimkoster_001">Ve manzara -- uğruna ölünesi.</Entry>
        <Entry Name="victimbabbles_victimkoster_010_victimkoster_001">İzin verseler burada yaşardım.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_001_victimstrohmeier_001">Doug, tornavidayı kendine ayırmayı bırak.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_002_victimstrohmeier_001">Güneş batıyor bile...</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_003_victimstrohmeier_001">Hadi şu şeyi çalıştıralım.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_004_victimstrohmeier_001">Endişelenme, gayet iyi uçacak.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_005_victimstrohmeier_001">Tarlaların üzerinde süzüleceğiz.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_006_victimstrohmeier_001">İnanılmaz olacak.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_007_victimstrohmeier_001">Sıkıldığımızda, kasabaya geri döneriz.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_008_victimstrohmeier_001">Biraz bira alır, biraz bilardo oynarız.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_009_victimstrohmeier_001">Tıpkı eski güzel günlerdeki gibi.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_010_victimstrohmeier_001">Şimdi şu lanet tornavidayı ver.</Entry>
        <Entry Name="victimbabbles_victimgoya_001_victimgoya_001">Kazandığıma inanamıyorum!</Entry>
        <Entry Name="victimbabbles_victimgoya_002_victimgoya_001">Bu tarihe geçer.</Entry>
        <Entry Name="victimbabbles_victimgoya_003_victimgoya_001">Artık sonunda gözüm açık gitmeyeceğim.</Entry>
        <Entry Name="victimbabbles_victimgoya_004_victimgoya_001">Unut gitsin, Terry. Artık oynamıyorum.</Entry>
        <Entry Name="victimbabbles_victimgoya_005_victimgoya_001">Vay canına... duydun mu, Brand?</Entry>
        <Entry Name="victimbabbles_victimgoya_006_victimgoya_001">Evet, kazandım. Kralı köşeye sıkıştırdım.</Entry>
        <Entry Name="victimbabbles_victimgoya_007_victimgoya_001">Oh, yeni bir sipariş mi gelmiş? Harika, hadi halledelim!</Entry>
        <Entry Name="victimbabbles_victimgoya_008_victimgoya_001">Yine bir iletişim uydusu mu?</Entry>
        <Entry Name="victimbabbles_victimgoya_009_victimgoya_001">Askeri mi? O zaman doğru yaptığımızdan emin olsak iyi olur.</Entry>
        <Entry Name="victimbabbles_victimgoya_010_victimgoya_001">Hadi, Brand. Bizim çocuklara yardım edelim.</Entry>
        <Entry Name="victimbabbles_victimfrost_001_victimfrost_001">Komiteye teşekkür etmek isterim.</Entry>
        <Entry Name="chase_akerschase_1_001_akers_001">Teklifimi neden reddediyorsun?</Entry>
        <Entry Name="chase_akerschase_2_001_akers_001">Görmüyor musun?</Entry>
        <Entry Name="chase_akerschase_3_001_akers_001">Bu mükemmel.</Entry>
        <Entry Name="chase_akerschase_4_001_akers_001">Ölüme kadar uyku.</Entry>
        <Entry Name="chase_akerschase_5_001_akers_001">Nasıl hayır diyebilirsin?</Entry>
        <Entry Name="chase_akerschase_6_001_akers_001">Seni yutmasına izin ver.</Entry>
        <Entry Name="chase_akerschase_7_001_akers_001">Rüya gör!</Entry>
        <Entry Name="chase_akerschase_8_001_akers_001">İsteyebileceğin tek şey bu!</Entry>
        <Entry Name="chase_akerschase_9_001_akers_001">Her zaman istediğin her şey.</Entry>
        <Entry Name="chase_akerschase_10_001_akers_001">Geriye hiçbir şey kalmadı.</Entry>
        <Entry Name="chase_akerschase_11_001_akers_001">Geride kalmak için hiçbir neden yok.</Entry>
        <Entry Name="chase_akerschase_capture_001_akers_001">Uykunun kollarına teslim ol.</Entry>
        <Entry Name="chase_akerschase_speech_1_001_akers_001">Senin için üzülüyorum -- diğerleri gibi uyuyamıyorsun.</Entry>
        <Entry Name="chase_akerschase_speech_2_001_akers_001">Endişelenme, boşa gitmene izin vermeyeceğim. Çoğun yenilebilir.</Entry>
        <Entry Name="chase_akerschase_death_001_akers_001">Hayıııır...</Entry>
        <Entry Name="victimbabbles_victimfrost_random_001_victimfrost_001">Teşekkür ederim.</Entry>
        <Entry Name="victimbabbles_victimfrost_random_002_victimfrost_001">Tanıştığımıza da memnun oldum.</Entry>
        <Entry Name="victimbabbles_victimfrost_random_003_victimfrost_001">Gerçekten onur duydum.</Entry>
        <Entry Name="victimbabbles_victimfrost_random_004_victimfrost_001">Rica ederim.</Entry>
        <Entry Name="victimbabbles_victimfrost_random_005_victimfrost_001">Bu hepimiz için harika bir keşif.</Entry>
        <Entry Name="victimbabbles_victimgoya_random_001_victimgoya_001">Sadece seviyelere göz kulak ol.</Entry>
        <Entry Name="victimbabbles_victimgoya_random_002_victimgoya_001">Onu şuradan alacağım.</Entry>
        <Entry Name="victimbabbles_victimgoya_random_003_victimgoya_001">Oluyor, oluyor.</Entry>
        <Entry Name="victimbabbles_victimgoya_random_004_victimgoya_001">Dikkatli ol, Brandon.</Entry>
        <Entry Name="victimbabbles_victimgoya_random_005_victimgoya_001">Yavaş ve sakince.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_random_001_victimstrohmeier_001">İşte oldu.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_random_002_victimstrohmeier_001">Onu senin için alayım.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_random_003_victimstrohmeier_001">İyi gidiyor.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_random_004_victimstrohmeier_001">Evet, bu iş görür.</Entry>
        <Entry Name="victimbabbles_victimstrohmeier_random_005_victimstrohmeier_001">Doug...</Entry>
        <Entry Name="victimbabbles_victimfrost_010_victimfrost_001">Bana ilham veren merhum Elliot Frost, bunca yıldır.</Entry>
        <Entry Name="victimbabbles_victimfrost_009_victimfrost_001">Bunu babama adamalıyım...</Entry>
        <Entry Name="victimbabbles_victimfrost_008_victimfrost_001">Belki de her şeyden daha büyüktür.</Entry>
        <Entry Name="victimbabbles_victimfrost_007_victimfrost_001">Yalnız olmadığımızı öğrenmek.</Entry>
        <Entry Name="victimbabbles_victimfrost_006_victimfrost_001">Heyecan verici bir zamanda yaşıyoruz.</Entry>
        <Entry Name="victimbabbles_victimfrost_005_victimfrost_001">Nihayet, sonunda tanındı.</Entry>
        <Entry Name="victimbabbles_victimfrost_004_victimfrost_001">Bunu sır olarak saklamak zor oldu.</Entry>
        <Entry Name="victimbabbles_victimfrost_003_victimfrost_001">Bu keşif herkese aittir.</Entry>
        <Entry Name="victimbabbles_victimfrost_002_victimfrost_001">Majesteleri Kraliçe Christina II, teşekkür ederim.</Entry>
    </CATEGORY>
</LANGUAGE>
