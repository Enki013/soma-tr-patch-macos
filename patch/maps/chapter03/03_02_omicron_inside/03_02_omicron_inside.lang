        <Entry Name="biolabaudiolog_biolabaudiolog_004_herber_001">O kadar şeffaf mıyım?</Entry>
        <Entry Name="biolabaudiolog_biolabaudiolog_005_dahl_001">Ne istiyorsun, Raleigh?</Entry>
        <Entry Name="biolabaudiolog_biolabaudiolog_006_herber_001">Arkadaşız, değil mi?</Entry>
