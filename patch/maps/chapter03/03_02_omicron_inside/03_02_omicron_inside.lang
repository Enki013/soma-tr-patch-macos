        <Entry Name="general_commterminal_2_002_herber_001">Net ve anlaşılır. Herkes iyi mi?</Entry>
        <Entry Name="general_commterminal_2_003_lindwall_001">Güç Kıyafetleri ile arkadaş olur olmaz olacağız.</Entry>
        <Entry Name="general_commterminal_2_004_herber_001">Alışacağına eminim.</Entry>
        <Entry Name="general_commterminal_2_005_hill_001">Hey, şuna bak.</Entry>
