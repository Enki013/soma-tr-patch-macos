<LANGUAGE>
    <CATEGORY Name="Voices_05_03_space">
        <Entry Name="general_finalwords_version1_001_player_001">Burası inanılmaz bir yer.</Entry>
        <Entry Name="general_finalwords_version1_002_catherine_001">Beğenmene sevindim.</Entry>
        <Entry Name="general_finalwords_version1_003_player_001">Çok canlı.</Entry>
        <Entry Name="general_finalwords_version2_001_player_001">Gerçekten başardığımıza inanamıyorum.</Entry>
        <Entry Name="general_finalwords_version2_002_catherine_001">Eh, başardık işte.</Entry>
        <Entry Name="general_finalwords_version2_003_player_001">Çok rahatladım.</Entry>
        <Entry Name="general_finalwords_version2_004_catherine_001">Sorun yok, Simon. Artık her şey yolunda.</Entry>
        <Entry Name="general_finalwords_version3_001_player_001">Herkes iyi mi? Hepsini kurtardık mı?</Entry>
        <Entry Name="general_finalwords_version3_002_catherine_001">Kurtardık. Herkesi kurtardık.</Entry>
        <Entry Name="general_finalwords_version4_001_player_001">Yıldızlar arasında sonsuzluk, değil mi?</Entry>
        <Entry Name="general_finalwords_version4_002_catherine_001">Doğru, Simon. Yıldızlar arasında sonsuzluk.</Entry>
