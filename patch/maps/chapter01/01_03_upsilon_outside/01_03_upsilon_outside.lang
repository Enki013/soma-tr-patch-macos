<LANGUAGE>
    <CATEGORY Name="Voices_01_03_upsilon_outside">
        <Entry Name="robottalk_scavenge_idle_001_scavengerobot_001">Çok boş.</Entry>
        <Entry Name="robottalk_scavenge_idle_002_scavengerobot_001">Herkes gitmiş.</Entry>
        <Entry Name="robottalk_scavenge_idle_003_scavengerobot_001">Ne kadar zaman geçti?</Entry>
        <Entry Name="robottalk_scavenge_idle_004_scavengerobot_001">Çok bitkin hissediyorum.</Entry>
        <Entry Name="robottalk_scavenge_idle_005_scavengerobot_001">Onları o kadar çok özlüyorum ki</Entry>
        <Entry Name="robottalk_scavenge_idle_006_scavengerobot_001">İnsan nasıl bu kadar susar? Dilim damağım kurudu.</Entry>
        <Entry Name="robottalk_scavenge_idle_007_scavengerobot_001">Buralarda biraz jel olmalı.</Entry>
        <Entry Name="robottalk_scavenge_idle_008_scavengerobot_001">Artık kendim gibi hissetmiyorum</Entry>
        <Entry Name="robottalk_scavenge_idle_010_scavengerobot_001">Buraya nasıl geldim?</Entry>
        <Entry Name="robottalk_scavenge_idle_011_scavengerobot_001">Burada ne işim var?</Entry>
        <Entry Name="robottalk_scavenge_idle_012_scavengerobot_001">Düzgün düşünemiyorum.</Entry>
        <Entry Name="robottalk_scavenge_idle_013_scavengerobot_001">Daha fazla structure gel'e ihtiyacım var.</Entry>
        <Entry Name="robottalk_scavenge_idle_014_scavengerobot_001">Kaybediyorum. Ölüyorum.</Entry>
        <Entry Name="robottalk_scavenge_idle_015_scavengerobot_001">Sakladılar mı?</Entry>
        <Entry Name="robottalk_scavenge_idle_019_scavengerobot_001">Beni burada bıraktılar.</Entry>
        <Entry Name="robottalk_scavenge_idle_020_scavengerobot_001">Gidecek yer yok.</Entry>
        <Entry Name="robottalk_scavenge_idle_021_scavengerobot_001">Biraz kan akıtmam lazım.</Entry>
        <Entry Name="robottalk_scavenge_idle_022_scavengerobot_001">Siyah kanı.</Entry>
        <Entry Name="robottalk_scavenge_idle_023_scavengerobot_001">Herkes gitmiş</Entry>
        <Entry Name="robottalk_scavenge_idle_024_scavengerobot_001">Wau bir şey yaptı, bir şey yapmış olmalı!</Entry>
        <Entry Name="robottalk_scavenge_idle_025_scavengerobot_001">İnsan nasıl bu kadar susar? Dilim damağım kurudu</Entry>
        <Entry Name="robottalk_scavenge_idle_026_scavengerobot_001">Buralarda biraz jel olmalı</Entry>
        <Entry Name="robottalk_scavenge_idle_027_scavengerobot_001">Herkes nereye gitti?</Entry>
        <Entry Name="robottalk_scavenge_idle_028_scavengerobot_001">Buraya nasıl geldim?</Entry>
        <Entry Name="robottalk_scavenge_idle_029_scavengerobot_001">Düzgün düşünemiyorum</Entry>
        <Entry Name="robottalk_scavenge_idle_030_scavengerobot_001">Kaybediyorum, ölüyorum</Entry>
        <Entry Name="robottalk_scavenge_idle_031_scavengerobot_001">Nereye sakladılar?</Entry>
        <Entry Name="robottalk_scavenge_idle_032_scavengerobot_001">Hepsini almışlar!</Entry>
        <Entry Name="robottalk_scavenge_idle_033_scavengerobot_001">Gidecek yer yok</Entry>
        <Entry Name="robottalk_scavenge_idle_034_scavengerobot_001">Siyah kan</Entry>
        <Entry Name="robottalk_scavenge_stalk_001_scavengerobot_001">Sende fazla var mı?</Entry>
        <Entry Name="robottalk_scavenge_stalk_002_scavengerobot_001">İhtiyacım var, biliyorsun.</Entry>
        <Entry Name="robottalk_scavenge_stalk_003_scavengerobot_001">Sadece biraz.</Entry>
        <Entry Name="robottalk_scavenge_stalk_004_scavengerobot_001">Hadi ama, idare etmek için.</Entry>
        <Entry Name="robottalk_scavenge_stalk_005_scavengerobot_001">Açgözlü olma.</Entry>
        <Entry Name="robottalk_scavenge_stalk_006_scavengerobot_001">Sende bolca var.</Entry>
        <Entry Name="robottalk_scavenge_stalk_007_scavengerobot_001">Böyle yapma.</Entry>
        <Entry Name="robottalk_scavenge_stalk_008_scavengerobot_001">Nasıl bir şey olduğunu biliyorsun.</Entry>
        <Entry Name="robottalk_scavenge_stalk_009_scavengerobot_001">Benimki bitti.</Entry>
        <Entry Name="robottalk_scavenge_stalk_015_scavengerobot_001">Ona ihtiyacım olduğunu biliyorsun.</Entry>
        <Entry Name="robottalk_scavenge_stalk_016_scavengerobot_001">Seni kalpsiz pislik.</Entry>
        <Entry Name="robottalk_scavenge_stalk_017_scavengerobot_001">Bana biraz structure gel ver.</Entry>
        <Entry Name="robottalk_scavenge_stalk_018_scavengerobot_001">Seni incitmek istemiyorum.</Entry>
        <Entry Name="robottalk_scavenge_stalk_019_scavengerobot_001">Paylaşabiliriz.</Entry>
        <Entry Name="robottalk_scavenge_stalk_020_scavengerobot_001">Buraya gel.</Entry>
        <Entry Name="robottalk_scavenge_stalk_022_scavengerobot_001">Beni kötü adam yapma.</Entry>
        <Entry Name="robottalk_scavenge_stalk_023_scavengerobot_001">Ona ihtiyacım var, biliyorsun</Entry>
        <Entry Name="robottalk_scavenge_stalk_024_scavengerobot_001">Sadece biraz</Entry>
        <Entry Name="robottalk_scavenge_stalk_025_scavengerobot_001">Açgözlü olma</Entry>
        <Entry Name="robottalk_scavenge_stalk_026_scavengerobot_001">Sende bolca var</Entry>
        <Entry Name="robottalk_scavenge_stalk_027_scavengerobot_001">Benimki bitti</Entry>
        <Entry Name="robottalk_scavenge_stalk_028_scavengerobot_001">Bana yalvartma</Entry>
        <Entry Name="robottalk_scavenge_stalk_029_scavengerobot_001">Bu ciddi bir durum</Entry>
        <Entry Name="robottalk_scavenge_stalk_030_scavengerobot_001">Benden vazgeçme</Entry>
        <Entry Name="robottalk_scavenge_stalk_031_scavengerobot_001">Seni açgözlü o... çocuğu</Entry>
        <Entry Name="robottalk_scavenge_stalk_032_scavengerobot_001">Bana biraz jel ver</Entry>
        <Entry Name="robottalk_scavenge_stalk_033_scavengerobot_001">Ona ihtiyacım olduğunu biliyorsun</Entry>
        <Entry Name="robottalk_scavenge_stalk_034_scavengerobot_001">Seni kalpsiz pislik</Entry>
        <Entry Name="robottalk_scavenge_stalk_035_scavengerobot_001">Bana biraz structure gel ver</Entry>
        <Entry Name="robottalk_scavenge_stalk_036_scavengerobot_001">Kimsenin canı yanmak zorunda değil</Entry>
        <Entry Name="robottalk_scavenge_stalk_037_scavengerobot_001">Beni kötü adam yapma</Entry>
        <Entry Name="robottalk_scavenge_tempted_001_scavengerobot_001">Neden bana bunu yaptırıyorsun?</Entry>
        <Entry Name="robottalk_scavenge_tempted_002_scavengerobot_001">Böyle olmamız benim suçum değil.</Entry>
        <Entry Name="robottalk_scavenge_tempted_003_scavengerobot_001">Bana biraz ver!</Entry>
        <Entry Name="robottalk_scavenge_tempted_004_scavengerobot_001">Ver onu buraya!</Entry>
        <Entry Name="robottalk_scavenge_tempted_005_scavengerobot_001">Ona ihtiyacım var!</Entry>
        <Entry Name="robottalk_scavenge_tempted_006_scavengerobot_001">Bencil olma!</Entry>
        <Entry Name="robottalk_scavenge_tempted_009_scavengerobot_001">Sende çok var.</Entry>
        <Entry Name="robottalk_scavenge_tempted_011_scavengerobot_001">Açlıktan ölmeme izin verme!</Entry>
        <Entry Name="robottalk_scavenge_tempted_012_scavengerobot_001">Daha fazlasına ihtiyacım var.</Entry>
        <Entry Name="robottalk_scavenge_tempted_014_scavengerobot_001">Gitmesine izin veremem!</Entry>
        <Entry Name="robottalk_scavenge_tempted_017_scavengerobot_001">Neden bana bunu yaptırıyorsun?</Entry>
        <Entry Name="robottalk_scavenge_tempted_018_scavengerobot_001">Bana biraz ver</Entry>
        <Entry Name="robottalk_scavenge_stalkfirststart_001_scavengerobot_001">Sen gerçeksin. Lütfen, acım için biraz ver.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_001_scavengerobot_001">Fikrini değiştirdin.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_002_scavengerobot_001">Seni tekrar görmek güzel.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_003_scavengerobot_001">Beni ölüme terk ettiğini sanmıştım.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_004_scavengerobot_001">Demek vicdanın sonunda sana yetişti.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_005_scavengerobot_001">Oh, demek bunu yapıyoruz.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_006_scavengerobot_001">Seni tekrar görmek güzel</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_007_scavengerobot_001">Demek vicdanın sonunda sana yetişti.</Entry>
        <Entry Name="robottalk_scavenge_stalkstart_008_scavengerobot_001">Oh, demek bunu yapıyoruz</Entry>
        <Entry Name="robottalk_scavenge_stalkend_001_scavengerobot_001">Gitme. Yardım et bana!</Entry>
        <Entry Name="robottalk_scavenge_stalkend_002_scavengerobot_001">İçinde vardı. Hissedebiliyordum.</Entry>
        <Entry Name="robottalk_scavenge_stalkend_003_scavengerobot_001">Hey, bekle! Geri gel.</Entry>
        <Entry Name="robottalk_scavenge_stalkend_004_scavengerobot_001">Geri dönecek, değil mi? Değil mi?</Entry>
        <Entry Name="robottalk_scavenge_stalkend_005_scavengerobot_001">Hey.. bekle! Geri gel!</Entry>
        <Entry Name="robottalk_scavenge_alert_001_scavengerobot_001">Neden saklanıyorsun?</Entry>
        <Entry Name="robottalk_scavenge_alert_002_scavengerobot_001">Çık dışarı, seni incitmeyeceğim.</Entry>
        <Entry Name="robottalk_scavenge_alert_003_scavengerobot_001">Sinsi sinsi dolaştığını duyuyorum.</Entry>
        <Entry Name="robottalk_scavenge_alert_004_scavengerobot_001">Orada olduğunu biliyorum. Seni duyabiliyorum.</Entry>
        <Entry Name="robottalk_scavenge_alert_006_scavengerobot_001">Korkmana gerek yok.</Entry>
        <Entry Name="robottalk_scavenge_alert_007_scavengerobot_001">Sana yardım edebilirim.</Entry>
        <Entry Name="robottalk_scavenge_alert_008_scavengerobot_001">Neden saklanıyorsun?</Entry>
        <Entry Name="robottalk_scavenge_alert_009_scavengerobot_001">Çık dışarı, seni incitmeyeceğim</Entry>
        <Entry Name="robottalk_scavenge_alert_010_scavengerobot_001">Sinsi sinsi dolaştığını duyuyorum</Entry>
        <Entry Name="robottalk_scavenge_alert_011_scavengerobot_001">Korkmana gerek yok!</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_001_scavengerobot_001">O da ne?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_002_scavengerobot_001">Kim var orada?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_003_scavengerobot_001">Bir şey duydum sandım.</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_004_scavengerobot_001">Kimse var mı?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_005_scavengerobot_001">Merhaba?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_007_scavengerobot_001">Neler oluyor?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_010_scavengerobot_001">Bunu kim yapıyor?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_011_scavengerobot_001">O da ne?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_012_scavengerobot_001">Bir şey duydum sandım!</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_013_scavengerobot_001">Kimse var mı?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_014_scavengerobot_001">Ne?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_015_scavengerobot_001">Neler oluyor?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_016_scavengerobot_001">O kim?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_017_scavengerobot_001">Orada biri mi var?</Entry>
        <Entry Name="robottalk_scavenge_alertbeforeseen_018_scavengerobot_001">Bunu kim yapıyor?</Entry>
        <Entry Name="simoncomments_intro_breath_001_player_001">Ne... ne oluyor böyle? Bu nasıl mümkün olabilir?</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_001_Echo_Amy_001">Theta, cevap ver? Cevap versen iyi olur, Strasky. Hadi!</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_002_Echo_Peter_001">Amy, neredesin?</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_003_Echo_Amy_001">Tarlalarda -- ayrılmak zorunda kaldım.</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_004_Echo_Peter_001">Carl seninle mi?</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_005_Echo_Amy_001">Her şey boka sardı.</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_006_Echo_Peter_001">Bekle. Gücü otomatikleştirdin, değil mi? Santral güvende mi? Tesisleri çalışır durumda tutmak için o güce ihtiyacımız var--</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_007_Echo_Amy_001">Sikeyim gücü! Sikeyim seni, Strasky! Makineler Carl'ı öldürdü!</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_008_Echo_Peter_001">Ah, siktir. Pekala, sakin ol, her şey yoluna girecek. Theta'ya geri dönebilir misin?</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_009_Echo_Amy_001">Evet, sanırım. Mekiğe, yedeğe gideceğim.</Entry>
        <Entry Name="Echo_Datamine_AmyTheta_010_Echo_Peter_001">İyi şanslar, Amy. Sana güveniyorum.</Entry>
        <Entry Name="simoncomments_leftcommroom_001_player_001">Bu... bu delilik...</Entry>
        <Entry Name="simoncomments_leftcommroom_objective_001_player_001">Lambda, Lambda'ya giden bir mekik bul.</Entry>
        <Entry Name="simoncomments_thankkatebot_001_player_001">Pekala, teşekkürler küçük adam!</Entry>
    </CATEGORY>
