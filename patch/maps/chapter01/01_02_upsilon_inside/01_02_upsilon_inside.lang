        <Entry Name="CarlConstruct_4D_RobotDatamine_005_Amy_001">Seni pislik.</Entry>
        <Entry Name="CarlConstruct_4E_CarlConstructPlea_1_001_CarlConstruct_001">Amy, sen misin? Pilot koltuğuna ne oldu?</Entry>
